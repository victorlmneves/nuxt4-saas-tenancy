{
    "name": "nuxt-saas-tenancy",
    "version": "0.1.0",
    "type": "module",
    "description": "Dynamic multi-tenancy for Nuxt 3 — runtime tenant resolution, caching, custom domains, and SSR-safe composables.",
    "license": "MIT",
    "keywords": [
        "nuxt",
        "nuxt3",
        "nuxt-module",
        "multi-tenant",
        "saas",
        "tenancy"
    ],
    "exports": {
        ".": {
            "import": "./dist/module.mjs",
            "require": "./dist/module.cjs"
        },
        "./types": "./dist/types.d.ts"
    },
    "main": "./dist/module.cjs",
    "types": "./dist/types.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "nuxt-module-build build",
        "dev": "nuxt-module-build build --stub && nuxi dev playground",
        "dev:build": "nuxi build playground",
        "lint": "eslint .",
        "format": "prettier --write '**/*.{ts,vue,js,json}' --ignore-path .gitignore && stylelint '**/*.{css,vue}' --ignore-pattern '.nuxt/**' --ignore-pattern '.output/**' --ignore-pattern 'coverage/**' --fix && eslint --fix '**/*.{ts,vue,js}' --ignore-pattern 'coverage/**'",
        "typecheck": "vue-tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "peerDependencies": {
        "@nuxt/kit": "^3.0.0 || ^4.0.0",
        "nuxt": "^3.0.0 || ^4.0.0"
    },
    "dependencies": {
        "defu": "^6.1.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@nuxt/eslint": "^1.13.0",
        "@nuxt/kit": "^4.0.0",
        "@nuxt/module-builder": "^1.0.2",
        "@nuxt/schema": "^4.0.0",
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "^4.1.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.5.0",
        "eslint-plugin-jsonc": "^2.21.0",
        "eslint-plugin-regexp": "^3.0.0",
        "eslint-plugin-vue": "^10.7.0",
        "globals": "^17.3.0",
        "nuxt": "^4.0.0",
        "postcss-html": "^1.8.1",
        "prettier": "^3.8.1",
        "stylelint": "^17.4.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-vue": "^1.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0",
        "vitest": "^4.1.0",
        "vue-eslint-parser": "^10.2.0"
    },
    "optionalDependencies": {
        "ioredis": "^5.0.0"
    }
}
